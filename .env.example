# Firebase configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="your-private-key"
FIREBASE_CLIENT_EMAIL=your-client-email

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Socket.IO CORS (allowed frontend origin)
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

#
# Notes:
# - Replace placeholder values with your actual credentials in your local .env file (never commit real secrets)
# - FIREBASE_PRIVATE_KEY should be wrapped in double quotes if multiline
# - SOCKET_IO_CORS_ORIGIN should match your frontend dev server or deployed URL